fallback_chain = []
enabled_providers = [
    "deepseek",
]
primary_provider = "deepseek"

[providers.deepseek]
protocol = "openai_compatible"
model = "deepseek-v4-flash"
provider_id = "deepseek"
api_key_env = "DEEPSEEK_API_KEY"
credential_id = "deepseek"
base_url = "https://api.deepseek.com/v1"

[budgets]
max_model_steps = 40
max_tool_calls = 100
max_runtime_seconds = 1800
shell_timeout_seconds = 120

[permission]
mode = "default"

[sandbox]
enabled = true
network_enabled = true

[context]
window_tokens = 128000
compaction_threshold = 0.8
preserve_recent_turns = 8
max_tool_result_chars = 20000

[trace]
enabled = true
include_tool_arguments = false
include_transient_events = false
retention_days = 7
max_total_mb = 100


[extensions]
enabled = true

[extensions.mcp_servers.gaodemap-mcp]
transport = "streamable_http"
enable = false
url = "https://mcp.api-inference.modelscope.net/6eea030bc1684a/mcp"
required = true

[storage]
project_state_root = ".windcode"
user_storage_root = "~/.windcode"

[memory]
enabled = true
extraction_enabled = true
recall_limit = 5
recall_max_chars = 12000
baseline_max_records = 30
baseline_max_chars = 6000
extraction_max_chars = 20000
extraction_max_output_tokens = 600
candidate_retention_days = 90
stale_after_days = 30
user_profile_enabled = true
project_knowledge_enabled = true
experience_enabled = true
sop_enabled = true
reference_enabled = true
